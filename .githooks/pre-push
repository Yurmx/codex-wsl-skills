#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if command -v python3 >/dev/null 2>&1; then
  python3 scripts/check_sanitization.py --history main
elif command -v py >/dev/null 2>&1; then
  py -3 scripts/check_sanitization.py --history main
elif command -v python >/dev/null 2>&1; then
  python scripts/check_sanitization.py --history main
else
  echo "sanitization pre-push hook requires python3, py -3, or python" >&2
  exit 1
fi
